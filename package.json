{
  "name": "acorn",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dist": "pnpm --filter @acorn/desktop dist",
    "rebuild": "pnpm --filter @acorn/desktop electron:rebuild",
    "rebuild:node": "pnpm --filter @acorn/desktop node:rebuild",
    "dev:node": "pnpm --filter @acorn/desktop dev:node",
    "db:generate": "pnpm --filter @acorn/desktop db:generate",
    "db:migrate": "pnpm --filter @acorn/desktop db:migrate"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
