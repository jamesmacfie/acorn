{
  "name": "@acorn/desktop",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite build && electron-vite preview",
    "dev:node": "node --import tsx --watch --env-file=.env src/main/server.ts",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --mac",
    "electron:dev": "electron-vite dev",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3,node-pty",
    "node:rebuild": "node scripts/rebuild-node-abi.mjs",
    "lint": "tsc --noEmit",
    "test": "node scripts/rebuild-node-abi.mjs && vitest run",
    "db:generate": "drizzle-kit generate && tsx scripts/check-migrations.ts",
    "db:check": "tsx scripts/check-migrations.ts",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solidjs/router": "^0.16.1",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-query-persist-client": "^5.101.0",
    "@tanstack/solid-virtual": "^3.13.29",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.11.1",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "gitdiff-parser": "^0.3.1",
    "hono": "^4.12.26",
    "idb-keyval": "^6.2.5",
    "jose": "^6.2.3",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "shiki": "^4.2.0",
    "smol-toml": "^1.7.0",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^8.0.0",
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
