{
  "name": "@acorn/web",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:node": "node --import tsx --watch --env-file=.dev.vars src/main/server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "node:rebuild": "pnpm rebuild better-sqlite3",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply acorn --local"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@solidjs/router": "^0.16.1",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-query-persist-client": "^5.101.0",
    "@tanstack/solid-virtual": "^3.13.29",
    "better-sqlite3": "^12.11.1",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "gitdiff-parser": "^0.3.1",
    "hono": "^4.12.26",
    "idb-keyval": "^6.2.5",
    "jose": "^6.2.3",
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@electron/rebuild": "^4.0.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^8.0.0",
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
